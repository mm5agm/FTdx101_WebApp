@model Tuple<string, string, string>
@{
    var bands = new[] { "160m", "80m", "60m", "40m", "30m", "20m", "17m", "15m", "12m", "10m", "6m", "4m" };
    var bandLabels = new Dictionary<string, string>
    {
        ["160m"] = "160 metres",
        ["80m"]  = "80 metres",
        ["60m"]  = "60 metres",
        ["40m"]  = "40 metres",
        ["30m"]  = "30 metres",
        ["20m"]  = "20 metres",
        ["17m"]  = "17 metres",
        ["15m"]  = "15 metres",
        ["12m"]  = "12 metres",
        ["10m"]  = "10 metres",
        ["6m"]   = "6 metres",
        ["4m"]   = "4 metres"
    };
    var receiver = Model.Item2;
    var selectedBand = (Model.Item3 ?? "").Trim().ToLowerInvariant();
}
<div class="band-buttons-container">
    <div class="band-radio-grid" id="bandRadioGroup@(receiver)">
        @for (int idx = 0; idx < bands.Length; idx++)
        {
            var band = bands[idx];
            var bandValue = band.Trim().ToLowerInvariant();
            var bandLabel = bandLabels.TryGetValue(band, out var lbl) ? lbl : band;
            <label class="band-radio-label">
                <input type="radio"
                       name="band-@receiver"
                       value="@band"
                       aria-label="@bandLabel"
                       data-a11y-key="bands.@band"
                       data-receiver="@receiver"
                       @(bandValue == selectedBand ? "checked" : "")>
                <span aria-hidden="true">@band</span>
            </label>
        }
    </div>
</div>
