@page
@model FTdx101_WebApp.Pages.MeterCalibration.IndexModel
@{
    ViewData["Title"] = "Meter Calibration";
}

<div class="calibration-page">
    <div class="calibration-header">
        <h2>Meter Calibration</h2>
        <p class="save-target">Save Target: <span id="saveTargetPath">Loading...</span></p>
        <div class="header-actions">
            <button id="saveAllBtn" class="btn-save">Save Calibration</button>
            <button id="resetViewBtn" class="btn-secondary">Reload From File</button>
            <button id="txBtn" class="btn-tx">TX</button>
            <button id="helpBtn" class="btn-help">? Help</button>
            <span id="saveStatus" class="save-status"></span>
        </div>
    </div>

    <div id="meterCards" class="meter-grid"></div>
</div>

@section Scripts {
    <script type="module">
        import {
            createSMeterGauge,
            createPowerGauge,
            createSWRGauge,
            createCompressionGauge,
            createALCGauge,
            createTempGauge,
            createIDDGauge,
            createVDDGauge
        } from "/js/guages/gaugeFactory.js";

        const meterUiConfig = [
            { name: "S-Meter", title: "S-Meter", type: "s_meter", statusPath: ["vfoA", "sMeter"], creator: createSMeterGauge },
            { name: "PWR", title: "Power", type: "numeric", statusPath: ["powerMeter"], creator: createPowerGauge },
            { name: "SWR", title: "SWR", type: "numeric", statusPath: ["swrMeter"], creator: createSWRGauge },
            { name: "Compression", title: "Compression", type: "numeric", statusPath: ["compressionMeter"], creator: createCompressionGauge },
            { name: "ALC", title: "ALC", type: "numeric", statusPath: ["alcMeter"], creator: createALCGauge },
            { name: "TPA", title: "PA Temperature", type: "numeric", statusPath: ["temperature"], creator: createTempGauge },
            { name: "IDD", title: "IDD", type: "numeric", statusPath: ["iddMeter"], creator: createIDDGauge },
            { name: "VPA", title: "VDD", type: "numeric", statusPath: ["vddMeter"], creator: createVDDGauge }
        ];

        let calibrationFile = { meters: [] };
        let gaugeInstances = {};
        let currentRaw = {};

        function getByPath(source, path) {
            return path.reduce((acc, key) => (acc && acc[key] !== undefined ? acc[key] : null), source);
        }

        function toNumber(value, fallback = 0) {
            const parsed = Number(value);
            return Number.isFinite(parsed) ? parsed : fallback;
        }

        function interpolate(points, raw) {
            const sorted = [...points].sort((a, b) => toNumber(a.raw) - toNumber(b.raw));
            if (sorted.length === 0) return 0;
            if (sorted.length === 1) return toNumber(sorted[0].Radio, raw);

            if (raw <= toNumber(sorted[0].raw)) return toNumber(sorted[0].Radio, raw);
            if (raw >= toNumber(sorted[sorted.length - 1].raw)) return toNumber(sorted[sorted.length - 1].Radio, raw);

            for (let i = 1; i < sorted.length; i++) {
                const a = sorted[i - 1];
                const b = sorted[i];
                const ax = toNumber(a.raw);
                const bx = toNumber(b.raw);
                if (raw <= bx) {
                    const ay = toNumber(a.Radio, ax);
                    const by = toNumber(b.Radio, bx);
                    const t = (raw - ax) / (bx - ax);
                    return ay + t * (by - ay);
                }
            }

            return toNumber(sorted[sorted.length - 1].Radio, raw);
        }

        function calibrateValue(meter, raw) {
            const points = meter.points || [];
            if (meter.type === "s_meter") {
                if (points.length === 0) return raw.toFixed(0);
                const sorted = [...points].sort((a, b) => toNumber(a.raw) - toNumber(b.raw));
                let selected = sorted[0];
                for (const point of sorted) {
                    if (raw < toNumber(point.raw)) break;
                    selected = point;
                }
                return selected.Radio || "";
            }

            return interpolate(points, raw).toFixed(1);
        }

        function updateGaugeNeedle(meterName, raw, calibrated) {
            const gauge = gaugeInstances[meterName]?.gauge;
            if (!gauge) return;

            const numericCal = toNumber(calibrated, raw);
            let needle = raw;

            if (meterName === "PWR") needle = numericCal;
            else if (meterName === "SWR") needle = Math.max(0, Math.min(255, (numericCal - 1.0) * 127.5));
            else if (meterName === "Compression") needle = numericCal;
            else if (meterName === "TPA") needle = numericCal;
            else if (meterName === "IDD") needle = numericCal;
            else if (meterName === "VPA") needle = numericCal;
            else if (meterName === "ALC") needle = raw;
            else if (meterName === "S-Meter") needle = raw;

            gauge.value = needle;
            gauge.draw();
        }

        function renderPointRows(meter, containerId) {
            const container = document.getElementById(containerId);
            container.innerHTML = "";

            meter.points.sort((a, b) => toNumber(a.raw) - toNumber(b.raw));

            meter.points.forEach((point, idx) => {
                const row = document.createElement("div");
                row.className = "point-row";

                const rawInput = document.createElement("input");
                rawInput.type = "number";
                rawInput.step = "1";
                rawInput.value = point.raw;
                rawInput.placeholder = "Raw";
                rawInput.addEventListener("input", e => {
                    point.raw = toNumber(e.target.value);
                    refreshCard(meter.name);
                });

                const radioInput = document.createElement("input");
                radioInput.type = "text";
                radioInput.value = point.Radio || "";
                radioInput.placeholder = "Radio";
                radioInput.addEventListener("input", e => {
                    point.Radio = e.target.value;
                    refreshCard(meter.name);
                });

                const deleteBtn = document.createElement("button");
                deleteBtn.type = "button";
                deleteBtn.textContent = "×";
                deleteBtn.className = "btn-remove";
                deleteBtn.addEventListener("click", () => {
                    meter.points.splice(idx, 1);
                    renderPointRows(meter, containerId);
                    refreshCard(meter.name);
                });

                row.appendChild(rawInput);
                row.appendChild(radioInput);
                row.appendChild(deleteBtn);
                container.appendChild(row);
            });
        }

        function refreshCard(meterName) {
            const meter = calibrationFile.meters.find(m => m.name === meterName);
            if (!meter) return;

            const raw = currentRaw[meterName] ?? 0;
            const calibrated = calibrateValue(meter, raw);

            const rawEl = document.getElementById(`raw-${meterName}`);
            const calEl = document.getElementById(`cal-${meterName}`);
            if (rawEl) rawEl.textContent = raw.toFixed(0);
            if (calEl) calEl.textContent = calibrated;

            const titleValueId = {
                "S-Meter": "",
                "PWR": "powerMeterValue",
                "SWR": "swrMeterValue",
                "Compression": "compressionMeterValue",
                "ALC": "alcMeterValue",
                "TPA": "paTemperatureValue",
                "IDD": "iddMeterValue",
                "VPA": "vddMeterValue"
            }[meterName];

            if (titleValueId) {
                const titleValueEl = document.getElementById(titleValueId);
                if (titleValueEl) {
                    if (meterName === "SWR") titleValueEl.textContent = `${toNumber(calibrated).toFixed(1)}:1`;
                    else titleValueEl.textContent = calibrated;
                }
            }

            updateGaugeNeedle(meterName, raw, calibrated);
        }

        function buildCard(meter, ui) {
            const key = meter.name;
            const card = document.createElement("section");
            card.className = "meter-card";
            card.innerHTML = `
                <h3>${ui.title}</h3>
                <div class="gauge-wrap"><canvas id="gauge-${key}" width="180" height="110"></canvas></div>
                <div class="meter-values">
                    <div>Raw: <span id="raw-${key}">0</span></div>
                    <div>Calibrated: <span id="cal-${key}">0</span></div>
                </div>
                <div class="point-header"><span>Raw Value</span><span>Radio Value</span><span></span></div>
                <div id="rows-${key}" class="point-list"></div>
                <div class="card-actions">
                    <button type="button" class="btn-secondary" id="add-${key}">Add Point</button>
                    <button type="button" class="btn-save" id="save-${key}">Save</button>
                    <span id="savestatus-${key}" class="card-save-status"></span>
                </div>
            `;

            document.getElementById("meterCards").appendChild(card);

            gaugeInstances[key] = ui.creator(`gauge-${key}`);
            gaugeInstances[key].render();

            document.getElementById(`add-${key}`).addEventListener("click", () => {
                const maxRaw = meter.points.length > 0 ? Math.max(...meter.points.map(p => toNumber(p.raw))) + 1 : 0;
                meter.points.push({ raw: maxRaw, Radio: "0" });
                renderPointRows(meter, `rows-${key}`);
                refreshCard(key);
            });

            document.getElementById(`save-${key}`).addEventListener("click", () => {
                saveCalibration(document.getElementById(`savestatus-${key}`));
            });

            renderPointRows(meter, `rows-${key}`);
            refreshCard(key);
        }

        // VDD filter state — mirrors the orchestrator to keep calibration page stable
        let _vddLastValid = 204;
        let _vddLastVolts = 48;

        function filterVDD(raw, meter) {
            const minRaw = 175;  // ~41.2V — margin above gauge minimum
            const maxRaw = 235;  // ~55V
            if (raw < minRaw || raw > maxRaw) return null;  // out of range — discard
            _vddLastValid = raw;
            const points = meter ? meter.points : [];
            const volts = points.length > 0 ? toNumber(interpolate(points, raw)) : raw;
            if (Math.abs(volts - _vddLastVolts) > 3 && _vddLastVolts !== 0) return null;  // sudden jump — discard
            _vddLastVolts = volts;
            return raw;
        }

        async function pollRawMeters() {
            try {
                const response = await fetch("/api/cat/status");
                if (!response.ok) return;
                const status = await response.json();

                for (const ui of meterUiConfig) {
                    let raw = toNumber(getByPath(status, ui.statusPath), 0);

                    if (ui.name === "VPA") {
                        const meter = calibrationFile.meters.find(m => m.name === "VPA");
                        const filtered = filterVDD(raw, meter);
                        if (filtered === null) continue;  // discard noisy reading
                        raw = filtered;
                    }

                    // IDD should read 0 when not transmitting
                    if (ui.name === "IDD" && !_isTx) {
                        raw = 0;
                    }

                    currentRaw[ui.name] = raw;
                    refreshCard(ui.name);
                }
            } catch (_) {
            }
        }

        async function saveCalibration(statusEl) {
            const saveStatus = statusEl ?? document.getElementById("saveStatus");
            saveStatus.textContent = "Saving...";

            calibrationFile.meters.forEach(m => {
                m.points = (m.points || []).map(p => ({
                    raw: toNumber(p.raw),
                    Radio: `${p.Radio ?? ""}`.trim()
                })).filter(p => p.Radio !== "");
            });

            const response = await fetch("/api/calibration/file", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(calibrationFile)
            });

            if (response.ok) {
                const data = await response.json();
                document.getElementById("saveTargetPath").textContent = data.saveTargetPath;
                saveStatus.textContent = "Saved";
                setTimeout(() => saveStatus.textContent = "", 2000);
                return;
            }

            saveStatus.textContent = "Save failed";
        }

        async function loadCalibration() {
            const response = await fetch("/api/calibration/file");
            const data = await response.json();
            calibrationFile = data.calibration;
            document.getElementById("saveTargetPath").textContent = data.saveTargetPath;

            const meterCards = document.getElementById("meterCards");
            meterCards.innerHTML = "";
            gaugeInstances = {};

            for (const ui of meterUiConfig) {
                const meter = calibrationFile.meters.find(m => m.name === ui.name);
                if (!meter) continue;
                buildCard(meter, ui);
            }

            await pollRawMeters();
        }

        document.getElementById("saveAllBtn").addEventListener("click", () => saveCalibration());
        document.getElementById("resetViewBtn").addEventListener("click", loadCalibration);

        // Help modal
        const helpModal = document.getElementById("helpModal");
        document.getElementById("helpBtn").addEventListener("click", () => helpModal.classList.add("open"));
        document.getElementById("helpClose").addEventListener("click", () => helpModal.classList.remove("open"));
        helpModal.addEventListener("click", e => { if (e.target === helpModal) helpModal.classList.remove("open"); });

        // TX button
        let _isTx = false;
        const txBtn = document.getElementById("txBtn");

        function updateTxBtn(transmitting) {
            _isTx = transmitting;
            if (transmitting) {
                txBtn.textContent = "TX ON";
                txBtn.classList.add("btn-tx-active");
            } else {
                txBtn.textContent = "TX";
                txBtn.classList.remove("btn-tx-active");
            }
        }

        async function syncTxState() {
            try {
                const r = await fetch("/api/cat/tx");
                if (r.ok) { const d = await r.json(); updateTxBtn(d.transmitting); }
            } catch (_) {}
        }

        txBtn.addEventListener("click", async () => {
            try {
                const r = await fetch("/api/cat/tx", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ transmit: !_isTx })
                });
                if (r.ok) { const d = await r.json(); updateTxBtn(d.transmitting); }
            } catch (_) {}
        });

        await syncTxState();

        await loadCalibration();
        setInterval(pollRawMeters, 750);
    </script>
}

<style>
