@page
@model FTdx101_WebApp.Pages.IndexModel
@{
    ViewData["Title"] = "FT-dx101 Series Control";
    var allModes = new[] {
        "LSB", "USB", "CW-U", "CW-L", "FM", "FM-N", "AM", "AM-N", "RTTY-L", "RTTY-U",
        "DATA-L", "DATA-U", "DATA-FM", "DATA-FM-N", "PSK"
    };
    // Display label shown in the dropdown — value stays as the CAT mode string.
    string ModeLabel(string m) => m == "DATA-FM-N" ? "D-FM-N" : m;
}

<!-- Cache-busted CSS reference -->
<link rel="stylesheet" href="~/css/site.css?v=20260406a" />
<link rel="stylesheet" href="~/css/closer-to-raw-power.css?v=20260226n" />

<!-- Message Box Modal (Windows-style) -->
<div class="modal fade" id="messageBoxModal" tabindex="-1" aria-labelledby="messageBoxTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content" style="border-radius: 4px; border: 2px solid #dc3545;">
            <div class="modal-header py-2" style="background: linear-gradient(to bottom, #dc3545, #c82333); border-bottom: 1px solid #bd2130;">
                <h6 class="modal-title text-white" id="messageBoxTitle" style="font-size: 0.9rem;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Warning
                </h6>
            </div>
            <div class="modal-body py-3" style="background: #fff;">
                <p id="messageBoxText" class="mb-0" style="font-size: 0.9rem; color: #000;"></p>
            </div>
            <div class="modal-footer py-2 justify-content-center" style="background: #f8f9fa; border-top: 1px solid #dee2e6;">
                <button type="button" class="btn btn-danger btn-sm px-4" data-bs-dismiss="modal" style="min-width: 80px;">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- Overlay for initialization status -->
<div id="initOverlay" class="init-overlay">
    <div class="init-message">
        <span id="initStatusText">Initializing radio, please wait...</span>
        <div class="spinner-border text-primary" role="status"></div>
    </div>
</div>

<div class="row mb-1" style="padding-top: 2px; padding-bottom: 2px;">
        @if (Model.ShowApp1Button)
        {
            <div class="col-auto">
                <button id="wsjtxBtn" class="btn btn-secondary btn-sm" style="padding-top: 1px; padding-bottom: 1px;"
                        onclick="launchWsjtx()" title="Launch @Model.App1Name">
                    @Model.App1Name
                    <span id="wsjtxTxBadge" class="badge bg-danger ms-1" style="display:none;">TX</span>
                </button>
            </div>
        }
        @if (Model.ShowApp2Button)
        {
            <div class="col-auto">
                <button id="jtalertBtn" class="btn btn-secondary btn-sm" style="padding-top: 1px; padding-bottom: 1px;"
                        onclick="launchJtalert()" title="Launch @Model.App2Name">
                    @Model.App2Name
                </button>
            </div>
        }
        @if (Model.ShowApp3Button)
        {
            <div class="col-auto">
                <button id="log4omBtn" class="btn btn-secondary btn-sm" style="padding-top: 1px; padding-bottom: 1px;"
                        onclick="launchLog4om()" title="Launch @Model.App3Name">
                    @Model.App3Name
                </button>
            </div>
        }
        <div class="col-auto ms-auto d-flex gap-2 align-items-center">
            <a href="https://paypal.me/mm5agm" target="_blank" rel="noopener noreferrer"
               class="btn btn-warning btn-sm" style="padding-top: 1px; padding-bottom: 1px;" title="Support this project via PayPal">
                <i class="bi bi-cup-hot-fill"></i> Buy Me a Coffee
            </a>
            <button id="radioPowerBtn" class="btn btn-danger btn-sm"
                    onclick="toggleRadioPower()" style="padding-top: 1px; padding-bottom: 1px;" title="Radio Power On/Off">
                <i class="bi bi-power"></i> POWER
            </button>
        </div>
    </div>
    <!-- Power and SWR Meters -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="card border-secondary">
                <div class="card-body py-2">
                    <!-- Gauges row -->
                    <div class="d-flex justify-content-start align-items-start flex-wrap" style="margin-left: 0; gap: 0; margin-bottom: 0.2rem !important;">
                        <!-- SWR Meter -->
                        <div class="text-center" style="position: relative; height: 135px; min-width: 220px; margin: 0; padding: 0;">
                            <div class="analog-meter-container">
                                <canvas id="swrMeterCanvas"></canvas>
                            </div>
                        </div>
                        <!-- Power Meter -->
                        <div class="text-center power-meter-container" style="position: relative; height: 135px; min-width: 220px; margin: 0; padding: 0;">
                            <div class="analog-meter-container">
                                <canvas id="powerMeterCanvas"></canvas>
                            </div>
                        </div>
                        <!-- Compression Meter -->
                        <div class="text-center" style="position: relative; height: 135px; min-width: 220px; margin: 0; padding: 0;">
                            <div class="analog-meter-container">
                                <canvas id="compressionMeterCanvas"></canvas>
                            </div>
                        </div>
                        <!-- ALC Meter -->
                        <div class="text-center" style="position: relative; height: 135px; min-width: 220px; margin: 0; padding: 0;">
                            <div class="analog-meter-container">
                                <canvas id="alcMeterCanvas"></canvas>
                            </div>
                        </div>
                        <!-- PA Temperature Meter -->
                        <div class="text-center" style="position: relative; height: 135px; min-width: 220px; margin: 0; padding: 0;">
                            <div class="analog-meter-container">
                                <canvas id="tempMeterCanvas"></canvas>
                            </div>
                        </div>
                        <!-- IDD Meter -->
                        <div class="text-center" style="position: relative; height: 135px; min-width: 220px; margin: 0; padding: 0;">
                            <div class="analog-meter-container">
                                <canvas id="iddMeterCanvas"></canvas>
                            </div>
                        </div>
                        <!-- VDD Meter -->
                        <div class="text-center" style="position: relative; height: 135px; min-width: 220px; margin: 0; padding: 0;">
                            <div class="analog-meter-container">
                                <canvas id="vddMeterCanvas"></canvas>
                            </div>
                        </div>
                    </div>
                    <!-- Power and MIC Gain on one row -->
                    <div class="d-flex align-items-center gap-2 mb-2 closer-to-raw-power" style="margin-top: -18px !important; flex-wrap: nowrap;">
                        <label class="mb-0 text-nowrap">Power: <span id="powerValue" class="fw-bold">0W</span></label>
                        <input type="range" class="form-range flex-shrink-0" id="powerSlider"
                               min="5" max="200" step="5"
                               value="@Model.RadioState.Power"
                               style="width: 150px; height: 18px;"
                               oninput="window.radioControl.updatePowerDisplay(window.txVfo === 1 ? 'B' : 'A', this.value)"
                               onchange="window.radioControl.setPower(window.txVfo === 1 ? 'B' : 'A', this.value)">
                        <label class="mb-0 text-nowrap ms-2"><span id="micGainLabel">MIC Gain</span>: <span id="micGainValue" class="fw-bold">@Model.MicGain</span></label>
                        <input type="range" class="form-range power-slider flex-shrink-0"
                               id="micGainSlider"
                               min="0" max="100" step="1"
                               value="@Model.MicGain"
                               style="width: 150px; height: 18px;"
                               oninput="document.getElementById('micGainValue').innerText = this.value;"
                               onchange="setMicGain(this.value);">
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Spectrum Display — hidden until SdrBackgroundService reports "streaming" -->
    <div id="spectrumContainer" class="row mt-3" style="display:none;">
        <div class="col-12">
            <div class="card border-dark">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-1">
                    <span class="small fw-bold"><i class="bi bi-broadcast-pin me-1"></i>Spectrum</span>
                    <div class="d-flex align-items-center gap-2">
                        <div class="btn-group btn-group-sm" role="group" aria-label="Spectrum span">
                            <button type="button" class="btn btn-outline-light btn-sm span-btn @(Model.SdrSampleRateHz == 250_000 ? "active" : "")" data-hz="250000">250k</button>
                            <button type="button" class="btn btn-outline-light btn-sm span-btn @(Model.SdrSampleRateHz == 500_000 ? "active" : "")" data-hz="500000">500k</button>
                            <button type="button" class="btn btn-outline-light btn-sm span-btn @(Model.SdrSampleRateHz == 1_024_000 ? "active" : "")" data-hz="1024000">1M</button>
                            <button type="button" class="btn btn-outline-light btn-sm span-btn @(Model.SdrSampleRateHz == 2_048_000 ? "active" : "")" data-hz="2048000">2M</button>
                        </div>
                        <span id="spectrumStatusBadge" class="badge bg-secondary small">—</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <canvas id="spectrumCanvas" style="display:block; width:100%;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 flex-wrap">
        <!-- VFO A Panel -->
        <div class="col-lg-6 col-12">
            <div class="card border-primary h-100 receiver-card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-1">
                    <h5 class="mb-0">
                        <span id="receiverAHeading">VFO A</span>
                    </h5>
                    <button id="txButtonA" class="btn btn-warning btn-sm" style="display:none;"
                            onclick="toggleTx()" title="Toggle Transmit">
                        <i class="bi bi-broadcast"></i> TX
                    </button>
                </div>
                <div class="card-body p-2">
                    <!-- Receiver Controls Group: S-Meter, Band buttons, Mode select -->
                    <div class="receiver-controls-group d-flex flex-nowrap mb-0 gap-2 align-items-start">
                        <!-- Left: S-Meter only -->
                        <div class="flex-shrink-0">
                            <div class="analog-meter-container">
                                <canvas id="sMeterCanvasA"></canvas>
                            </div>
                        </div>
                        <!-- Middle: Band buttons + Mode/Antenna below -->
                        <div class="flex-grow-1 d-flex flex-column gap-1">
                            @await Html.PartialAsync("_BandButtonsPartial", Tuple.Create("unused", "A", Model.SelectedBandA))
                            <div class="d-flex gap-2 mt-1">
                                <select class="form-select form-select-sm vfo-mode-select" id="modeSelectA"
                                        onchange="setMode('A', this.value)">
                                    @foreach (var mode in allModes)
                                    {
                                        @if (Model.RadioState.ModeA == mode)
                                        {
                                            <option value="@mode" selected>@ModeLabel(mode)</option>
                                        }
                                        else
                                        {
                                            <option value="@mode">@ModeLabel(mode)</option>
                                        }
                                    }
                                </select>
                                <select class="form-select form-select-sm vfo-ant-select" id="antennaSelectA"
                                        onchange="window.radioControl.setAntenna('A', this.value)">
                                    @foreach (var ant in new[] { "1", "2", "3" })
                                    {
                                        @if (Model.RadioState.AntennaA == ant)
                                        {
                                            <option value="@ant" selected>ANT @ant</option>
                                        }
                                        else
                                        {
                                            <option value="@ant">ANT @ant</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <!-- Right: Controls column (2-column grid) -->
                        <div class="vfo-controls-column">
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">AGC</label>
                                <select class="form-select form-select-sm" id="agcSelectA"
                                        onchange="window.radioControl.setAgc('A', this.value)">
                                    <option value="0">OFF</option>
                                    <option value="1">FAST</option>
                                    <option value="2" selected>MID</option>
                                    <option value="3">SLOW</option>
                                    <option value="4">AUTO</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">IPO/AMP</label>
                                <select class="form-select form-select-sm" id="ipoSelectA"
                                        onchange="window.radioControl.setIpo('A', this.value)">
                                    <option value="0" selected>IPO</option>
                                    <option value="1">AMP1</option>
                                    <option value="2">AMP2</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">ATT</label>
                                <select class="form-select form-select-sm" id="attSelectA"
                                        onchange="window.radioControl.setAttenuator('A', this.value)">
                                    <option value="00" selected>OFF</option>
                                    <option value="06">6 dB</option>
                                    <option value="12">12 dB</option>
                                    <option value="18">18 dB</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">NR</label>
                                <select class="form-select form-select-sm" id="nrSelectA"
                                        onchange="window.radioControl.setNr('A', this.value)">
                                    <option value="0" selected>OFF</option>
                                    <option value="1">NR1</option>
                                    <option value="2">NR2</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">NB</label>
                                <select class="form-select form-select-sm" id="nbSelectA"
                                        onchange="window.radioControl.setNoiseBlanker('A', this.value)">
                                    <option value="0" selected>OFF</option>
                                    <option value="1">ON</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">Auto Notch</label>
                                <select class="form-select form-select-sm" id="autoNotchSelectA"
                                        onchange="window.radioControl.setAutoNotch('A', this.value)">
                                    <option value="0" selected>OFF</option>
                                    <option value="1">ON</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">Man Notch</label>
                                <select class="form-select form-select-sm" id="manualNotchSelectA"
                                        onchange="window.radioControl.setManualNotch('A', this.value)">
                                    <option value="0" selected>OFF</option>
                                    <option value="1">ON</option>
                                </select>
                            </div>
                            <div class="vfo-control-item" style="grid-column: 1 / -1;">
                                <label class="vfo-control-label">Notch Hz</label>
                                <input type="range" id="manualNotchFreqA" min="10" max="3200" step="10" value="1000"
                                       style="flex: 1; height: 16px;"
                                       oninput="document.getElementById('manualNotchFreqValueA').textContent = this.value + ' Hz'; window.radioControl.setManualNotchFreq('A', this.value)">
                                <span id="manualNotchFreqValueA" class="vfo-control-label" style="min-width: 52px; text-align: right;">1000 Hz</span>
                            </div>
                        </div>
                    </div>

                    <!-- Segment selector — left-aligned, above frequency digits -->
                    <div class="d-flex align-items-center gap-1 mb-1" style="margin-top: 2px;">
                        <span class="fw-bold" style="font-size: 0.8rem; white-space: nowrap;">Segment</span>
                        <select class="form-select form-select-sm segment-select" id="segmentSelectA"
                                onchange="window.onSegmentChange && window.onSegmentChange('A', this.value)">
                            <option value="">--</option>
                        </select>
                    </div>

                    <!-- Frequency + Roofing + AF Gain on one row -->
                    <div class="d-flex align-items-center flex-wrap gap-2 mb-1" style="margin-top: -2px;">
                        <span id="freqA" class="fw-bold frequency-display digit-display"></span>
                        <span class="frequency-display digit-display">MHz</span>
                        <div id="freqA-controls" style="display:none;">
                            <button id="freqA-up" class="btn btn-secondary btn-sm">▲</button>
                            <button id="freqA-down" class="btn btn-secondary btn-sm">▼</button>
                        </div>
                        <label class="mb-0 text-nowrap ms-1 fw-bold">Roofing:</label>
                        <select class="form-select form-select-sm fw-bold flex-shrink-0" id="roofingFilterSelectA"
                                style="width: auto;"
                                onchange="window.radioControl.setRoofingFilter('A', this.value)">
                            <option value="6">12 kHz</option>
                            <option value="7">3 kHz</option>
                            <option value="8">1.2 kHz</option>
                            <option value="9">600 Hz</option>
                            <option value="A">300 Hz</option>
                        </select>
                        <label class="mb-0 text-nowrap ms-1 fw-bold">AF Gain: <span id="afGainValueA" class="fw-bold">0</span></label>
                        <input type="range" class="form-range afgain-slider flex-shrink-0"
                               id="afGainSliderA"
                               min="0" max="255" step="1" value="0"
                               style="width: 120px; height: 18px;"
                               oninput="document.getElementById('afGainValueA').innerText = this.value; updateAfGainFill('afGainSliderA'); setAfGain('A', this.value)">
                    </div>

                    <!-- IF Width and IF Shift -->
                    <div class="d-flex align-items-center gap-2 mb-0" style="flex-wrap: nowrap;">
                        <label class="mb-0 text-nowrap fw-bold">I.F. Width:</label>
                        <select class="form-select form-select-sm fw-bold flex-shrink-0" id="ifWidthSelectA"
                                style="width: auto;"
                                onchange="window.radioControl.setIfWidth('A', this.value)">
                            <option value="0" selected="@(Model.RadioState.IfWidthA=="0" ? "selected" : null)">200 Hz</option>
                            <option value="1" selected="@(Model.RadioState.IfWidthA=="1" ? "selected" : null)">400 Hz</option>
                            <option value="2" selected="@(Model.RadioState.IfWidthA=="2" ? "selected" : null)">600 Hz</option>
                            <option value="3" selected="@(Model.RadioState.IfWidthA=="3" ? "selected" : null)">850 Hz</option>
                            <option value="4" selected="@(Model.RadioState.IfWidthA=="4" ? "selected" : null)">1.2 kHz</option>
                            <option value="5" selected="@(Model.RadioState.IfWidthA=="5" ? "selected" : null)">1.4 kHz</option>
                            <option value="6" selected="@(Model.RadioState.IfWidthA=="6" ? "selected" : null)">1.8 kHz</option>
                            <option value="7" selected="@(Model.RadioState.IfWidthA=="7" ? "selected" : null)">2.4 kHz</option>
                            <option value="8" selected="@(Model.RadioState.IfWidthA=="8"||string.IsNullOrEmpty(Model.RadioState.IfWidthA) ? "selected" : null)">3.0 kHz</option>
                        </select>
                        <label class="mb-0 text-nowrap ms-1 fw-bold">I.F. Shift: <span id="ifShiftValueA" class="fw-bold">@Model.RadioState.IfShiftA</span></label>
                        <input type="range" class="form-range ifshift-slider flex-shrink-0"
                               id="ifShiftSliderA"
                               min="-1000" max="1000" step="20" value="@Model.RadioState.IfShiftA"
                               style="width: 120px; height: 18px;"
                               oninput="document.getElementById('ifShiftValueA').textContent = this.value">
                        <button type="button" class="btn btn-secondary btn-sm flex-shrink-0"
                                onclick="resetIfShift('A')" title="Zero IF Shift">Zero</button>
                    </div>
                            </div>
                        </div>
                    </div>
                    <!-- VFO B Panel -->
        <div class="col-lg-6 col-12">
            <div class="card border-success h-100 receiver-card">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center py-1">
                    <h5 class="mb-0">
                        <span id="receiverBHeading">VFO B</span>
                    </h5>
                    <button id="txButtonB" class="btn btn-warning btn-sm" style="display:none;"
                            onclick="toggleTx()" title="Toggle Transmit">
                        <i class="bi bi-broadcast"></i> TX
                    </button>
                </div>
                <div class="card-body p-2">
                    <!-- Receiver Controls Group: S-Meter, Band buttons, Mode select -->
                    <div class="receiver-controls-group d-flex flex-nowrap mb-0 gap-2 align-items-start">
                        <!-- Left: S-Meter only -->
                        <div class="flex-shrink-0">
                            <div class="analog-meter-container">
                                <canvas id="sMeterCanvasB"></canvas>
                            </div>
                        </div>
                        <!-- Middle: Band buttons + Mode/Antenna below -->
                        <div class="flex-grow-1 band-buttons-shifted d-flex flex-column gap-1">
                            @await Html.PartialAsync("_BandButtonsPartial", Tuple.Create("unused", "B", Model.SelectedBandB))
                            <div class="d-flex gap-2 mt-1">
                                <select class="form-select form-select-sm vfo-mode-select" id="modeSelectB"
                                        onchange="setMode('B', this.value)">
                                    @foreach (var mode in allModes)
                                    {
                                        @if (Model.RadioState.ModeB == mode)
                                        {
                                            <option value="@mode" selected>@ModeLabel(mode)</option>
                                        }
                                        else
                                        {
                                            <option value="@mode">@ModeLabel(mode)</option>
                                        }
                                    }
                                </select>
                                <select class="form-select form-select-sm vfo-ant-select" id="antennaSelectB"
                                        onchange="window.radioControl.setAntenna('B', this.value)">
                                    @foreach (var ant in new[] { "1", "2", "3" })
                                    {
                                        @if (Model.RadioState.AntennaB == ant)
                                        {
                                            <option value="@ant" selected>ANT @ant</option>
                                        }
                                        else
                                        {
                                            <option value="@ant">ANT @ant</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <!-- Right: Controls column (2-column grid) -->
                        <div class="vfo-controls-column">
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">AGC</label>
                                <select class="form-select form-select-sm" id="agcSelectB"
                                        onchange="window.radioControl.setAgc('B', this.value)">
                                    <option value="0">OFF</option>
                                    <option value="1">FAST</option>
                                    <option value="2" selected>MID</option>
                                    <option value="3">SLOW</option>
                                    <option value="4">AUTO</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">IPO/AMP</label>
                                <select class="form-select form-select-sm" id="ipoSelectB"
                                        onchange="window.radioControl.setIpo('B', this.value)">
                                    <option value="0" selected>IPO</option>
                                    <option value="1">AMP1</option>
                                    <option value="2">AMP2</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">ATT</label>
                                <select class="form-select form-select-sm" id="attSelectB"
                                        onchange="window.radioControl.setAttenuator('B', this.value)">
                                    <option value="00" selected>OFF</option>
                                    <option value="06">6 dB</option>
                                    <option value="12">12 dB</option>
                                    <option value="18">18 dB</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">NR</label>
                                <select class="form-select form-select-sm" id="nrSelectB"
                                        onchange="window.radioControl.setNr('B', this.value)">
                                    <option value="0" selected>OFF</option>
                                    <option value="1">NR1</option>
                                    <option value="2">NR2</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">NB</label>
                                <select class="form-select form-select-sm" id="nbSelectB"
                                        onchange="window.radioControl.setNoiseBlanker('B', this.value)">
                                    <option value="0" selected>OFF</option>
                                    <option value="1">ON</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">Auto Notch</label>
                                <select class="form-select form-select-sm" id="autoNotchSelectB"
                                        onchange="window.radioControl.setAutoNotch('B', this.value)">
                                    <option value="0" selected>OFF</option>
                                    <option value="1">ON</option>
                                </select>
                            </div>
                            <div class="vfo-control-item">
                                <label class="vfo-control-label">Man Notch</label>
                                <select class="form-select form-select-sm" id="manualNotchSelectB"
                                        onchange="window.radioControl.setManualNotch('B', this.value)">
                                    <option value="0" selected>OFF</option>
                                    <option value="1">ON</option>
                                </select>
                            </div>
                            <div class="vfo-control-item" style="grid-column: 1 / -1;">
                                <label class="vfo-control-label">Notch Hz</label>
                                <input type="range" id="manualNotchFreqB" min="10" max="3200" step="10" value="1000"
                                       style="flex: 1; height: 16px;"
                                       oninput="document.getElementById('manualNotchFreqValueB').textContent = this.value + ' Hz'; window.radioControl.setManualNotchFreq('B', this.value)">
                                <span id="manualNotchFreqValueB" class="vfo-control-label" style="min-width: 52px; text-align: right;">1000 Hz</span>
                            </div>
                        </div>
                    </div>

                    <!-- Segment selector — left-aligned, above frequency digits -->
                    <div class="d-flex align-items-center gap-1 mb-1" style="margin-top: 2px;">
                        <span class="fw-bold" style="font-size: 0.8rem; white-space: nowrap;">Segment</span>
                        <select class="form-select form-select-sm segment-select" id="segmentSelectB"
                                onchange="window.onSegmentChange && window.onSegmentChange('B', this.value)">
                            <option value="">--</option>
                        </select>
                    </div>

                    <!-- Frequency + Roofing + AF Gain on one row -->
                    <div class="d-flex align-items-center flex-wrap gap-2 mb-1" style="margin-top: -2px;">
                        <span id="freqB" class="fw-bold frequency-display digit-display"></span>
                        <span class="frequency-display digit-display">MHz</span>
                        <div id="freqB-controls" style="display:none;">
                            <button id="freqB-up" class="btn btn-secondary btn-sm">▲</button>
                            <button id="freqB-down" class="btn btn-secondary btn-sm">▼</button>
                        </div>
                        <label class="mb-0 text-nowrap ms-1 fw-bold">Roofing:</label>
                        <select class="form-select form-select-sm fw-bold flex-shrink-0" id="roofingFilterSelectB"
                                style="width: auto;"
                                onchange="window.radioControl.setRoofingFilter('B', this.value)">
                            <option value="6">12 kHz</option>
                            <option value="7">3 kHz</option>
                            <option value="8">1.2 kHz</option>
                            <option value="9">600 Hz</option>
                            <option value="A">300 Hz</option>
                        </select>
                        <label class="mb-0 text-nowrap ms-1 fw-bold">AF Gain: <span id="afGainValueB" class="fw-bold">0</span></label>
                        <input type="range" class="form-range afgain-slider flex-shrink-0"
                               id="afGainSliderB"
                               min="0" max="255" step="1" value="0"
                               style="width: 120px; height: 18px;"
                               oninput="document.getElementById('afGainValueB').innerText = this.value; updateAfGainFill('afGainSliderB'); setAfGain('B', this.value)">
                    </div>

                    <!-- IF Width and IF Shift -->
                    <div class="d-flex align-items-center gap-2 mb-0" style="flex-wrap: nowrap;">
                        <label class="mb-0 text-nowrap fw-bold">I.F. Width:</label>
                        <select class="form-select form-select-sm fw-bold flex-shrink-0" id="ifWidthSelectB"
                                style="width: auto;"
                                onchange="window.radioControl.setIfWidth('B', this.value)">
                            <option value="0" selected="@(Model.RadioState.IfWidthB=="0" ? "selected" : null)">200 Hz</option>
                            <option value="1" selected="@(Model.RadioState.IfWidthB=="1" ? "selected" : null)">400 Hz</option>
                            <option value="2" selected="@(Model.RadioState.IfWidthB=="2" ? "selected" : null)">600 Hz</option>
                            <option value="3" selected="@(Model.RadioState.IfWidthB=="3" ? "selected" : null)">850 Hz</option>
                            <option value="4" selected="@(Model.RadioState.IfWidthB=="4" ? "selected" : null)">1.2 kHz</option>
                            <option value="5" selected="@(Model.RadioState.IfWidthB=="5" ? "selected" : null)">1.4 kHz</option>
                            <option value="6" selected="@(Model.RadioState.IfWidthB=="6" ? "selected" : null)">1.8 kHz</option>
                            <option value="7" selected="@(Model.RadioState.IfWidthB=="7" ? "selected" : null)">2.4 kHz</option>
                            <option value="8" selected="@(Model.RadioState.IfWidthB=="8"||string.IsNullOrEmpty(Model.RadioState.IfWidthB) ? "selected" : null)">3.0 kHz</option>
                        </select>
                        <label class="mb-0 text-nowrap ms-1 fw-bold">I.F. Shift: <span id="ifShiftValueB" class="fw-bold">@Model.RadioState.IfShiftB</span></label>
                        <input type="range" class="form-range ifshift-slider flex-shrink-0"
                               id="ifShiftSliderB"
                               min="-1000" max="1000" step="20" value="@Model.RadioState.IfShiftB"
                               style="width: 120px; height: 18px;"
                               oninput="document.getElementById('ifShiftValueB').textContent = this.value">
                        <button type="button" class="btn btn-secondary btn-sm flex-shrink-0"
                                onclick="resetIfShift('B')" title="Zero IF Shift">Zero</button>
                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
@section Scripts {
    <!-- Cache-busted JS reference, placed BEFORE your inline script if you use window.radioControl, etc. -->
    <script>window.bandPlan = '@Model.BandPlan';</script>
    <script type="module">
        import { MeterPanel }           from "/js/guages/meter-panel.js";
        import { FTdx101Meters }        from "/js/orchestrators/FTdx101Meters.js";
        import { SdrSpectrumPipeline }  from "/js/sdr/sdr-spectrum-pipeline.js";
        import { SpectrumPanel }        from "/js/sdr/spectrum-panel.js";
        import { BAND_PLANS, getSegments } from "/js/ui/band-plan.js";
        window.bandPlanData = BAND_PLANS;
        window.getBandSegments = getSegments;
        document.addEventListener('DOMContentLoaded', function () {
            window.meterPanel = new MeterPanel({
                smeterA:     { type: 'smeter', canvasId: 'sMeterCanvasA' },
                smeterB:     { type: 'smeter', canvasId: 'sMeterCanvasB' },
                power:       { canvasId: 'powerMeterCanvas' },
                swr:         { canvasId: 'swrMeterCanvas' },
                compression: { canvasId: 'compressionMeterCanvas' },
                alc:         { canvasId: 'alcMeterCanvas' },
                temp:        { canvasId: 'tempMeterCanvas' },
                idd:         { canvasId: 'iddMeterCanvas' },
                vdd:         { canvasId: 'vddMeterCanvas' }
            });
            window.ftdx101Meters = new FTdx101Meters(window.meterPanel, window.calibrationEngine);

            // ── Spectrum display ─────────────────────────────────────────────
            // SpectrumPanel owns the canvas and all DOM for the spectrum display.
            // SdrSpectrumPipeline is pure transport/routing — no DOM, no canvas.
            const spectrumPanel = new SpectrumPanel(
                'spectrumCanvas',
                'spectrumContainer',
                @Model.RadioState.FrequencyA   // server-rendered initial VFO A frequency
            );

            const spectrumPipeline = new SdrSpectrumPipeline();

            spectrumPipeline.onSpectrumUpdate(data  => spectrumPanel.update(data));
            spectrumPipeline.onStatusChange(status  => {
                spectrumPanel.setStatus(status);
                const badge = document.getElementById('spectrumStatusBadge');
                if (badge) {
                    const labels = {
                        unconfigured: ['secondary', 'No SDR'],
                        connecting:   ['warning',   'Connecting…'],
                        streaming:    ['success',   'Live'],
                        disconnected: ['danger',    'Disconnected'],
                        nodll:        ['danger',    'No SoapySDR'],
                    };
                    const [colour, text] = labels[status] ?? ['secondary', status];
                    badge.className = `badge bg-${colour} small`;
                    badge.textContent = text;
                }
            });
            spectrumPipeline.onFrequencyA(hz => spectrumPanel.setVfoFrequency(hz));
            spectrumPipeline.onError(detail => spectrumPanel.setError(detail));

            spectrumPipeline.connect();
            window.spectrumPanel = spectrumPanel;

            // Span selector — POST new sample rate and restart the SDR stream.
            document.querySelectorAll('.span-btn').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const hz = btn.dataset.hz;
                    try {
                        const res = await fetch(`/api/sdr/span?hz=${hz}`, { method: 'POST' });
                        if (res.ok) {
                            document.querySelectorAll('.span-btn').forEach(b => b.classList.remove('active'));
                            btn.classList.add('active');
                        }
                    } catch { /* network error — ignore */ }
                });
            });
        });
        async function launchWsjtx() {
            try {
                const response = await fetch('/api/wsjtx/launch', { method: 'POST' });
                if (response.ok) {
                    const data = await response.json();
                    if (data.alreadyRunning) {
                        console.log('WSJT-X is already running, brought window to front');
                        // Optional: show a brief message to the user
                        const btn = document.getElementById('wsjtxBtn');
                        const originalText = btn.innerHTML;
                        btn.innerHTML = 'WSJT-X Already Running';
                        setTimeout(() => { btn.innerHTML = originalText; }, 2000);
                    }
                } else {
                    const data = await response.json();
                    alert(data.error || 'Failed to launch WSJT-X');
                }
            } catch (e) {
                alert('Error launching WSJT-X: ' + e.message);
            }
        }

        async function updateWsjtxStatus() {
            try {
                const response = await fetch('/api/wsjtx/status');
                if (response.ok) {
                    const data = await response.json();
                    const btn = document.getElementById('wsjtxBtn');
                    const txBadge = document.getElementById('wsjtxTxBadge');

                    // Green = UDP connected (WSJT-X talking to us)
                    // Yellow = process running but no UDP yet
                    // Grey = not running
                    btn.classList.remove('btn-secondary', 'btn-success', 'btn-warning', 'btn-danger');
                    if (data.connected) {
                        btn.classList.add('btn-success');
                        btn.title = 'WSJT-X connected' + (data.mode ? ' \u2014 ' + data.mode : '');
                    } else if (data.running) {
                        btn.classList.add('btn-warning');
                        btn.title = 'WSJT-X running \u2014 waiting for UDP data';
                    } else {
                        btn.classList.add('btn-danger');
                        btn.title = 'WSJT-X is not running';
                    }

                    // Red TX badge when transmitting
                    if (txBadge) {
                        txBadge.style.display = data.transmitting ? 'inline' : 'none';
                    }
                }
            } catch (e) { /* ignore */ }
        }

        updateWsjtxStatus();
        setInterval(updateWsjtxStatus, 5000);

        // JTAlert launch and status functions
        async function launchJtalert() {
            try {
                const response = await fetch('/api/jtalert/launch', { method: 'POST' });
                const btn = document.getElementById('jtalertBtn');
                if (response.ok) {
                    const data = await response.json();
                    btn.classList.remove('btn-secondary');
                    btn.classList.add('btn-success');
                    btn.title = 'JTAlert is running';
                    if (data.alreadyRunning) {
                        console.log('JTAlert is already running, brought window to front');
                        const originalText = btn.innerHTML;
                        btn.innerHTML = 'JTAlert Already Running';
                        setTimeout(() => { btn.innerHTML = originalText; }, 2000);
                    }
                } else {
                    const data = await response.json();
                    alert(data.error || 'Failed to launch JTAlert');
                }
            } catch (e) {
                alert('Error launching JTAlert: ' + e.message);
            }
        }

        async function updateJtalertStatus() {
            try {
                const response = await fetch('/api/jtalert/status');
                if (response.ok) {
                    const data = await response.json();
                    console.log('[JTAlert Status Poll]', data); // Debug log
                    const btn = document.getElementById('jtalertBtn');

                    btn.classList.remove('btn-secondary', 'btn-success', 'btn-warning', 'btn-danger');
                    if (data.running) {
                        btn.classList.add('btn-success');
                        btn.title = 'JTAlert is running';
                    } else {
                        btn.classList.add('btn-danger');
                        btn.title = 'JTAlert is not running';
                    }
                }
            } catch (e) { /* ignore */ }
        }

        updateJtalertStatus();
        setInterval(updateJtalertStatus, 5000);

        // Log4OM launch and status functions
        async function launchLog4om() {
            try {
                const response = await fetch('/api/log4om/launch', { method: 'POST' });
                const btn = document.getElementById('log4omBtn');
                if (response.ok) {
                    const data = await response.json();
                    btn.classList.remove('btn-secondary');
                    btn.classList.add('btn-success');
                    btn.title = 'Log4OM is running';
                    if (data.alreadyRunning) {
                        console.log('Log4OM is already running, brought window to front');
                        const originalText = btn.innerHTML;
                        btn.innerHTML = 'Log4OM Already Running';
                        setTimeout(() => { btn.innerHTML = originalText; }, 2000);
                    }
                } else {
                    const data = await response.json();
                    alert(data.error || 'Failed to launch Log4OM');
                }
            } catch (e) {
                alert('Error launching Log4OM: ' + e.message);
            }
        }

        async function updateLog4omStatus() {
            try {
                const response = await fetch('/api/log4om/status');
                if (response.ok) {
                    const data = await response.json();
                    console.log('[Log4OM Status Poll]', data); // Debug log
                    const btn = document.getElementById('log4omBtn');

                    btn.classList.remove('btn-secondary', 'btn-success', 'btn-warning', 'btn-danger');
                    if (data.running) {
                        btn.classList.add('btn-success');
                        btn.title = 'Log4OM is running';
                    } else {
                        btn.classList.add('btn-danger');
                        btn.title = 'Log4OM is not running';
                    }
                }
            } catch (e) { /* ignore */ }
        }

        updateLog4omStatus();
        setInterval(updateLog4omStatus, 5000);

        window.setAfGain = async function(receiver, val) {
    let band = receiver === 'A' ? '0' : '1';
    let value = String(val).padStart(3, '0');
    try {
        const response = await fetch('/api/cat/afgain', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ band, value })
        });
        if (!response.ok) {
            const data = await response.json();
            alert(data.error || 'Failed to set AF Gain');
        }
    } catch (e) {
        alert('Error setting AF Gain: ' + e.message);
    }
}

        async function setMicGain(value) {
            console.log('[setMicGain] Called with value:', value);
            try {
                const response = await fetch('/api/cat/micgain', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ value: parseInt(value) })
                });
                console.log('[setMicGain] API response status:', response.status);
                if (!response.ok) {
                    const data = await response.json();
                    console.error('Failed to set MIC Gain:', data.error);
                } else {
                    console.log('[setMicGain] Successfully set MIC Gain to', value);
                }
            } catch (e) {
                console.error('Error setting MIC Gain:', e.message);
            }
        }

        function updateAfGainFill(sliderId) {
            const slider = document.getElementById(sliderId);
            const value = parseInt(slider.value, 10);
            const max = parseInt(slider.max, 10);
            const pct = (value / max) * 100;
            slider.style.background = `linear-gradient(to right, #198754 0%, #198754 ${pct}%, #dee2e6 ${pct}%, #dee2e6 100%)`;
        }

        document.addEventListener('DOMContentLoaded', function() {
            updateAfGainFill('afGainSliderA');
            updateAfGainFill('afGainSliderB');
        });

        // Expose functions called from HTML onclick/onchange attributes
        window.launchWsjtx  = launchWsjtx;
        window.launchJtalert = launchJtalert;
        window.launchLog4om  = launchLog4om;
        window.setMicGain    = setMicGain;
        window.updateAfGainFill = updateAfGainFill;
    </script>
}