@page
@model FTdx101_WebApp.Pages.CalibrationModel
@{
    ViewData["Title"] = "Meter Calibration";
}

<div class="calibration-bg">
    <h2 class="mb-4" style="color:#2563eb;font-weight:700;letter-spacing:0.02em;">Meter Calibration</h2>
    <form method="post">
        <div class="row g-4 mb-2 justify-content-center">
            <div class="col-12 col-md-6 col-lg-3 d-flex justify-content-center align-items-start calibration-col">
                <fieldset class="calibration-card">
                    <legend>S-Meter</legend>
                    <table class="table table-sm mb-2">
                        <thead><tr><th>S-Point / Value</th><th></th></tr></thead>
                        <tbody>
                        @if (Model.Calibration.SMeter.Points.Count > 0)
                        {
                            for (int i = 0; i < Model.Calibration.SMeter.Points.Count; i++) {
                                <tr>
                                    <td>
                                        <input type="hidden" name="Calibration.SMeter.Points.index" value="@i" />
                                        <input asp-for="Calibration.SMeter.Points[@i].GaugeValue" class="form-control d-inline-block mb-1 s-meter-gauge-input" type="text" autocomplete="off" />
                                        <input asp-for="Calibration.SMeter.Points[@i].ActualValue" class="form-control d-inline-block mb-1" type="text" inputmode="decimal" pattern="[0-9]*\.?[0-9]*" autocomplete="off" />
                                    </td>
                                    <td style="width:1%;padding:0;">
                                        <button name="RemoveSMeterPoint-@i" class="btn btn-link text-danger p-0 m-0 align-middle" type="submit" title="Remove point">&times;</button>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                    <button name="AddSMeterPoint" class="btn btn-sm btn-secondary" type="submit">Add Point</button>
                </fieldset>
            </div>
            <div class="col-12 col-md-6 col-lg-3 d-flex justify-content-center align-items-start calibration-col">
                <fieldset class="calibration-card swr">
                    <legend>SWR</legend>
                    <table class="table table-sm mb-2">
                        <thead><tr><th>Gauge Value / Actual Value</th><th></th></tr></thead>
                        <tbody>
                        @if (Model.Calibration.SWR.Points.Count > 0)
                        {
                            for (int i = 0; i < Model.Calibration.SWR.Points.Count; i++) {
                                <tr>
                                    <td>
                                        <input type="hidden" name="Calibration.SWR.Points.index" value="@i" />
                                        <input asp-for="Calibration.SWR.Points[@i].GaugeValue" class="form-control d-inline-block mb-1" type="text" inputmode="decimal" pattern="[0-9]*\.?[0-9]*" autocomplete="off" />
                                        <input asp-for="Calibration.SWR.Points[@i].ActualValue" class="form-control d-inline-block mb-1" type="text" inputmode="decimal" pattern="[0-9]*\.?[0-9]*" autocomplete="off" />
                                    </td>
                                    <td style="width:1%;padding:0;">
                                        <button name="RemoveSWRPoint-@i" class="btn btn-link text-danger p-0 m-0 align-middle" type="submit" title="Remove point">&times;</button>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                    <button name="AddSWRPoint" class="btn btn-sm btn-secondary" type="submit">Add Point</button>
                </fieldset>
            </div>
            <div class="col-12 col-md-6 col-lg-3 d-flex justify-content-center align-items-start calibration-col">
                <fieldset class="calibration-card power">
                    <legend>Power</legend>
                    <table class="table table-sm mb-2">
                        <thead><tr><th>Gauge Value / Actual Value</th><th></th></tr></thead>
                        <tbody>
                        @for (int i = 0; i < Model.Calibration.Power.Points.Count; i++) {
                            <tr>
                                <td>
                                    <input type="hidden" name="Calibration.Power.Points.index" value="@i" />
                                    <input asp-for="Calibration.Power.Points[@i].GaugeValue" class="form-control d-inline-block mb-1" type="text" inputmode="decimal" pattern="[0-9]*\.?[0-9]*" autocomplete="off" />
                                    <input asp-for="Calibration.Power.Points[@i].ActualValue" class="form-control d-inline-block mb-1" type="text" inputmode="decimal" pattern="[0-9]*\.?[0-9]*" autocomplete="off" />
                                </td>
                                <td style="width:1%;padding:0;">
                                    <button name="RemovePowerPoint-@i" class="btn btn-link text-danger p-0 m-0 align-middle" type="submit" title="Remove point">&times;</button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                    <button name="AddPowerPoint" class="btn btn-sm btn-secondary" type="submit">Add Point</button>
                </fieldset>
            </div>
            <div class="col-12 col-md-6 col-lg-3 d-flex justify-content-center align-items-start calibration-col">
                <fieldset class="calibration-card alc">
                    <legend>ALC</legend>
                    <table class="table table-sm mb-2">
                        <thead><tr><th>Gauge Value / Actual Value</th><th></th></tr></thead>
                        <tbody>
                        @if (Model.Calibration.ALC.Points.Count > 0)
                        {
                            for (int i = 0; i < Model.Calibration.ALC.Points.Count; i++) {
                                <tr>
                                    <td>
                                        <input type="hidden" name="Calibration.ALC.Points.index" value="@i" />
                                        <input asp-for="Calibration.ALC.Points[@i].GaugeValue" class="form-control d-inline-block mb-1" type="text" inputmode="decimal" pattern="[0-9]*\.?[0-9]*" autocomplete="off" />
                                        <input asp-for="Calibration.ALC.Points[@i].ActualValue" class="form-control d-inline-block mb-1" type="text" inputmode="decimal" pattern="[0-9]*\.?[0-9]*" autocomplete="off" />
                                    </td>
                                    <td style="width:1%;padding:0;">
                                        <button name="RemoveALCPoint-@i" class="btn btn-link text-danger p-0 m-0 align-middle" type="submit" title="Remove point">&times;</button>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                    <button name="AddALCPoint" class="btn btn-sm btn-secondary" type="submit">Add Point</button>
                </fieldset>
            </div>
        </div>
        <div class="text-center">
            <button type="submit" class="save calibration-save-btn" id="saveCalibrationBtn">Save Calibration</button>
        </div>
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="calibration-status">@Model.StatusMessage</div>
        }
    </form>
</div>
