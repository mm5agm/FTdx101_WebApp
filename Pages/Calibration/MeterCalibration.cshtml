@page
@model FTdx101_WebApp.Pages.Calibration.MeterCalibrationModel
@{
    ViewData["Title"] = "Meter Calibration";
}

<div class="meter-calibration-container">
    <h2>Meter Calibration</h2>
    <div class="gauge-section">
        <canvas id="meterCalibrationGauge" width="420" height="135"></canvas>
    </div>
    <div class="current-value-label">
        Current RM Value: <span id="currentMeterRM">@Model.CurrentRawValue</span>
    </div>
    <div class="calibration-labels">
        <span>Label</span> / <span>Raw Value</span>
    </div>
    <form method="post">
        <div class="calibration-points-list">
            @for (int i = 0; i < Model.Calibration.Points.Count; i++)
            {
                <div class="calibration-point-row">
                    <input type="text" name="Calibration.Points[@i].Radio" value="@(Model.Calibration.Points[i].Radio ?? Model.Calibration.Points[i].Label)" placeholder="Label" class="calibration-label-input" />
                    <input type="number" name="Calibration.Points[@i].Raw" value="@Model.Calibration.Points[i].Raw" step="1" class="calibration-raw-input" />
                    <button type="submit" name="delete" value="@i" class="delete-point-btn">×</button>
                </div>
            }
        </div>
        <button type="submit" name="add" value="1" class="add-point-btn">Add Point</button>
        <button type="button" id="saveCalibrationBtn" class="save-btn">Save Calibration</button>
        <div id="saveCalibrationMsg" class="save-message" style="display:none"></div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('saveCalibrationBtn').addEventListener('click', function () {
            const rows = document.querySelectorAll('.calibration-point-row');
            const points = [];
            rows.forEach(function (row) {
                const label = row.querySelector('.calibration-label-input').value.trim();
                const raw = parseFloat(row.querySelector('.calibration-raw-input').value);
                if (!isNaN(raw)) {
                    points.push({ label: label, raw: raw });
                }
            });

            const payload = {
                meters: [{
                    name: 'S-Meter',
                    type: 's_meter',
                    isGauge: true,
                    units: 'S-units',
                    points: points
                }]
            };

            const msgEl = document.getElementById('saveCalibrationMsg');
            msgEl.style.display = 'none';

            fetch('/api/calibration/file', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(function (r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function () {
                msgEl.textContent = 'Calibration saved.';
                msgEl.style.color = '#16a34a';
                msgEl.style.display = 'block';
            })
            .catch(function (err) {
                msgEl.textContent = 'Save failed: ' + err.message;
                msgEl.style.color = '#dc2626';
                msgEl.style.display = 'block';
            });
        });
    </script>
}

<style>
.meter-calibration-container {
    border: 2px solid #4f8cff;
    border-radius: 1rem;
    padding: 1.5rem;
    margin: 2rem auto;
    max-width: 500px;
    background: #f8f9fa;
}
.gauge-section {
    text-align: center;
    margin-bottom: 1rem;
}
.current-value-label {
    font-weight: bold;
    margin-bottom: 0.5rem;
}
.calibration-labels {
    display: flex;
    justify-content: space-between;
    font-weight: 600;
    margin-bottom: 0.5rem;
}
.calibration-points-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
}
.calibration-point-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
}
.calibration-label-input, .calibration-raw-input {
    flex: 1 1 0;
    padding: 0.3rem 0.5rem;
    border-radius: 0.3rem;
    border: 1px solid #bcd;
    font-size: 1rem;
}
.delete-point-btn {
    background: #ef4444;
    color: #fff;
    border: none;
    border-radius: 0.3rem;
    font-size: 1.2rem;
    width: 2rem;
    height: 2rem;
    cursor: pointer;
}
.add-point-btn {
    background: #4f8cff;
    color: #fff;
    border: none;
    border-radius: 0.3rem;
    padding: 0.5rem 1.2rem;
    font-size: 1rem;
    margin-right: 0.5rem;
    cursor: pointer;
}
.save-btn {
    background: #22c55e;
    color: #fff;
    border: none;
    border-radius: 0.3rem;
    padding: 0.5rem 1.2rem;
    font-size: 1rem;
    cursor: pointer;
}
.save-message {
    margin-top: 0.75rem;
    color: #16a34a;
    font-weight: 600;
}
</style>
