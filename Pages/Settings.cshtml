@page
@model FTdx101_WebApp.Pages.SettingsModel

<div style="color: red; font-weight: bold; margin-bottom: 1em;">
    If this page appeared when you started the program it means that, either your rig isn't switched on, or your COM port settings are wrong!
</div>

<div class="mt-4">
    <h1 class="display-4 mb-4">Settings</h1>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert @(Model.StatusMessage.Contains("success") || Model.StatusMessage.Contains("✓") ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Network Access URLs Card -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <div class="card border-info h-100">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="bi bi-globe"></i> Network Access URLs</h4>
                </div>
                <div class="card-body">
                    <div class="list-group mb-3">
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1"><i class="bi bi-laptop"></i> Local Access (This PC)</h6>
                                    <code class="fs-5" id="localUrl">http://localhost:8080</code>
                                </div>
                                <button class="btn btn-sm btn-outline-primary" onclick="copyToClipboard('localUrl')">
                                    <i class="bi bi-clipboard"></i> Copy
                                </button>
                            </div>
                        </div>
                        @if (Model.NetworkAddresses != null && Model.NetworkAddresses.Any())
                        {
                            @foreach (var addr in Model.NetworkAddresses)
                            {
                                var urlId = $"netUrl{addr.Replace(".", "_")}";
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1"><i class="bi bi-tablet"></i> Network Access (Tablets/Phones)</h6>
                                            <code class="fs-5" id="@urlId">http://@addr:8080</code>
                                            @if (addr.StartsWith("192.168") || addr.StartsWith("10.") || addr.StartsWith("172."))
                                            {
                                                <small class="text-muted d-block">Private Network</small>
                                            }
                                        </div>
                                        <button class="btn btn-sm btn-outline-primary" onclick="copyToClipboard('@urlId')">
                                            <i class="bi bi-clipboard"></i> Copy
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="list-group-item">
                                <div class="alert alert-warning mb-0">
                                    <i class="bi bi-exclamation-triangle"></i> No network interfaces detected. Connect to a network to access from other devices.
                                </div>
                            </div>
                        }
                    </div>
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle"></i> <strong>Tip:</strong> Bookmark these URLs on your tablets and phones for quick access!
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header">
                    <h4 class="mb-0">Current Configuration</h4>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Radio Model:</dt>
                        <dd class="col-sm-8">
                            <code>@Model.Settings.RadioModel</code>
                            @if (Model.Settings.RadioModel == "FTdx101MP")
                            {
                                <span class="badge bg-primary">200W Output</span>
                            }
                            else
                            {
                                <span class="badge bg-info">100W Output</span>
                            }
                        </dd>
                        <dt class="col-sm-4">Serial Port:</dt>
                        <dd class="col-sm-8"><code>@Model.Settings.SerialPort</code></dd>
                        <dt class="col-sm-4">Baud Rate:</dt>
                        <dd class="col-sm-8"><code>@Model.Settings.BaudRate</code></dd>
                        <dt class="col-sm-4">Network Interface:</dt>
                        <dd class="col-sm-8">
                            <code>@Model.Settings.WebAddress</code>
                            @if (Model.Settings.WebAddress == "0.0.0.0")
                            {
                                <span class="badge bg-success">All Interfaces</span>
                            }
                            else if (Model.Settings.WebAddress == "localhost")
                            {
                                <span class="badge bg-secondary">Local Only</span>
                            }
                        </dd>
                        <dt class="col-sm-4">Web Port:</dt>
                        <dd class="col-sm-8"><code>8080</code></dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>Configuration</h3>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="row">
                    <div class="col-md-6">
                        <h5 class="mb-3">Radio Connection</h5>
                        <div class="mb-3">
                            <label asp-for="Settings.RadioModel" class="form-label">Radio Model</label>
                            <select asp-for="Settings.RadioModel" class="form-select">
                                <option value="FTdx101MP">FTdx101MP</option>
                                <option value="FTdx101D">FTdx101D</option>
                            </select>
                            <div class="form-text">
                                <strong>FTdx101MP:</strong> 200W output, includes additional roofing filters<br />
                                <strong>FTdx101D:</strong> 100W output<br />
                                Both models have dual receivers (VFO A and VFO B)
                            </div>
                            <span asp-validation-for="Settings.RadioModel" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Settings.SerialPort" class="form-label">Serial Port</label>
                            <input asp-for="Settings.SerialPort" class="form-control" placeholder="COM3" required />
                            <div class="form-text">
                                Enter the COM port where your radio is connected (e.g., COM3, COM4).
                                <br /><strong>Tip:</strong> Check Device Manager to find the correct port.
                            </div>
                            <span asp-validation-for="Settings.SerialPort" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Settings.BaudRate" class="form-label">Baud Rate</label>
                            <select asp-for="Settings.BaudRate" class="form-select">
                                <option value="4800">4800</option>
                                <option value="9600">9600</option>
                                <option value="19200">19200</option>
                                <option value="38400" selected>38400 (Default)</option>
                                <option value="57600">57600</option>
                                <option value="115200">115200</option>
                            </select>
                            <div class="form-text">
                                Select the baud rate configured in your radio.
                                <br /><strong>Default:</strong> 38400 for FT-dx101 Series
                            </div>
                            <span asp-validation-for="Settings.BaudRate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h5 class="mb-3">Web Server</h5>
                        <div class="mb-3">
                            <label class="form-label">Network Interface</label>
                            <select asp-for="Settings.WebAddress" class="form-select" id="webAddressSelect">
                                <option value="localhost">localhost (This PC only)</option>
                                <option value="0.0.0.0" selected>All Interfaces (Recommended - works with DHCP and Static IP)</option>
                                @if (Model.NetworkAddresses != null)
                                {
                                    @foreach (var addr in Model.NetworkAddresses)
                                    {
                                        <option value="@addr">@addr (Specific IP)</option>
                                    }
                                }
                            </select>
                            <div class="form-text">
                                <strong>localhost:</strong> Only accessible from this computer<br />
                                <strong>All Interfaces (0.0.0.0):</strong> Best choice - works regardless of DHCP or Static IP<br />
                                <strong>Specific IP:</strong> Bind to a particular network interface
                            </div>
                            <span asp-validation-for="Settings.WebAddress" class="text-danger"></span>
                        </div>
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> <strong>Port:</strong> The web server always uses port <strong>8080</strong>.
                        </div>
                        <div class="alert alert-warning" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <strong>Important:</strong> Save Settings and Restart the application after changing web server settings.
                        </div>
                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-app-indicator"></i>
                            <strong>External Applications:</strong> Configure WSJT-X, JTAlert, and Log4OM on the 
                            <a asp-page="/ApplicationSetup" class="alert-link">Application Setup</a> page.
                        </div>
                    </div>
                </div>
                <div class="row mt-4">
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-save"></i> Save Settings
                        </button>
                        <button type="button" class="btn btn-success btn-lg ms-2" onclick="testConnection()">
                            <i class="bi bi-plug"></i> Test Connection
                        </button>
                        <a asp-page="/Index" class="btn btn-secondary btn-lg ms-2">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <!-- SDR Spectrum Display -->
    <div class="card mt-4">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0"><i class="bi bi-broadcast-pin"></i> SDR Spectrum Display</h4>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">
                Connect your radio's <strong>IF output (RCA)</strong> to an SDR receiver. The spectrum
                display shows the band around your current VFO frequency in real time.
            </p>
            <div class="alert alert-info mb-3">
                <strong>Supported hardware:</strong> Any SDR supported by
                <a href="https://github.com/pothosware/SoapySDR/wiki" target="_blank" rel="noopener">SoapySDR</a>
                — RTL-SDR, SDRplay, Airspy, HackRF, LimeSDR and many more.
                <br>
                <strong>Installation:</strong> Install
                <a href="https://cubicsdr.com/" target="_blank" rel="noopener">CubicSDR</a> or
                <a href="https://github.com/f4exb/sdrangel/releases" target="_blank" rel="noopener">SDRangel</a>
                — both include SoapySDR and device plugins in their Windows installers.
                For SDRplay devices also install the
                <a href="https://www.sdrplay.com/softwaredownloads/" target="_blank" rel="noopener">official SDRplay API</a>.
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">SDR Device</label>
                        <div class="input-group">
                            <select class="form-select" id="sdrDeviceDropdown">
                                <option value="">— click Scan to detect devices —</option>
                            </select>
                            <button type="button" class="btn btn-outline-secondary" id="sdrScanBtn"
                                    onclick="scanSdrDevices()">
                                <i class="bi bi-search"></i> Scan
                            </button>
                        </div>
                        <div class="form-text">
                            Plug in your SDR before scanning. The selected device key is saved below.
                        </div>
                        <!-- Hidden field that binds to ApplicationSettings.SdrDeviceKey on POST -->
                        <input type="hidden" asp-for="Settings.SdrDeviceKey" id="sdrDeviceKeyInput" />
                        <div id="sdrDeviceKeyDisplay" class="mt-1 font-monospace small text-muted"></div>
                        <div id="sdrScanNotes" class="mt-2"></div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Settings.SdrIfFrequencyHz" class="form-label fw-bold">IF Frequency (Hz)</label>
                        <input asp-for="Settings.SdrIfFrequencyHz" class="form-control" type="number"
                               min="1000000" max="100000000" step="1000" />
                        <div class="form-text">
                            The radio's IF output frequency. <strong>FTdx101 series: 9,000,000 Hz.</strong>
                            ELAD FDM-DUO via USB: set to match the device's IQ centre frequency.
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Settings.SdrSampleRateHz" class="form-label fw-bold">Sample Rate (Hz)</label>
                        <select asp-for="Settings.SdrSampleRateHz" class="form-select">
                            <option value="1024000">1,024,000 — 1 MHz span</option>
                            <option value="2048000">2,048,000 — 2 MHz span (recommended)</option>
                            <option value="2500000">2,500,000 — 2.5 MHz span</option>
                            <option value="3200000">3,200,000 — 3.2 MHz span</option>
                        </select>
                        <div class="form-text">
                            Higher rates give a wider visible span but require more CPU.
                            Not all devices support all rates.
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Settings.SdrFftSize" class="form-label fw-bold">FFT Size</label>
                        <select asp-for="Settings.SdrFftSize" class="form-select">
                            <option value="512">512 — faster, less frequency resolution</option>
                            <option value="1024">1024 — recommended</option>
                            <option value="2048">2048 — higher resolution, more CPU</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <button type="button" class="btn btn-outline-danger btn-sm"
                                onclick="clearSdrDevice()">
                            <i class="bi bi-x-circle"></i> Disable SDR / Clear Device
                        </button>
                        <div class="form-text">Removes the saved device; the spectrum panel will be hidden.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header">
            <h4>Current Configuration</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Radio Model:</dt>
                <dd class="col-sm-9">
                    <code>@Model.Settings.RadioModel</code>
                    @if (Model.Settings.RadioModel == "FTdx101MP")
                    {
                        <span class="badge bg-primary">200W Output</span>
                    }
                    else
                    {
                        <span class="badge bg-info">100W Output</span>
                    }
                </dd>
                <dt class="col-sm-3">Serial Port:</dt>
                <dd class="col-sm-9"><code>@Model.Settings.SerialPort</code></dd>
                <dt class="col-sm-3">Baud Rate:</dt>
                <dd class="col-sm-9"><code>@Model.Settings.BaudRate</code></dd>
                <dt class="col-sm-3">Network Interface:</dt>
                <dd class="col-sm-9">
                    <code>@Model.Settings.WebAddress</code>
                    @if (Model.Settings.WebAddress == "0.0.0.0")
                    {
                        <span class="badge bg-success">All Interfaces</span>
                    }
                    else if (Model.Settings.WebAddress == "localhost")
                    {
                        <span class="badge bg-secondary">Local Only</span>
                    }
                </dd>
                <dt class="col-sm-3">Web Port:</dt>
                <dd class="col-sm-9"><code>8080</code></dd>
            </dl>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module">
        // Initialise the SDR device dropdown from the saved key on page load.
        document.addEventListener('DOMContentLoaded', () => {
            const savedKey = document.getElementById('sdrDeviceKeyInput').value;
            updateDeviceKeyDisplay(savedKey);
        });

        // Populate the SDR dropdown by calling the device enumeration API.
        window.scanSdrDevices = async function () {
            const btn      = document.getElementById('sdrScanBtn');
            const dropdown = document.getElementById('sdrDeviceDropdown');
            const notesDiv = document.getElementById('sdrScanNotes');
            const savedKey = document.getElementById('sdrDeviceKeyInput').value;

            btn.disabled   = true;
            btn.innerHTML  = '<span class="spinner-border spinner-border-sm me-1"></span>Scanning…';
            notesDiv.innerHTML = '';

            try {
                const resp                = await fetch('/api/sdr/devices');
                const { devices, notes }  = await resp.json();

                dropdown.innerHTML = '';

                // Always offer a "none / disabled" option.
                const noneOpt = document.createElement('option');
                noneOpt.value       = '';
                noneOpt.textContent = '— None (disable spectrum display) —';
                dropdown.appendChild(noneOpt);

                if (devices.length > 0) {
                    devices.forEach(d => {
                        const opt = document.createElement('option');
                        opt.value       = d.key;
                        opt.textContent = `${d.label} [${d.driver}]`;
                        if (d.key === savedKey) opt.selected = true;
                        dropdown.appendChild(opt);
                    });

                    // If the saved key didn't appear in the fresh scan, keep it as a manual entry.
                    if (savedKey && !devices.some(d => d.key === savedKey)) {
                        const opt = document.createElement('option');
                        opt.value       = savedKey;
                        opt.textContent = `(Previously saved) ${savedKey}`;
                        opt.selected    = true;
                        dropdown.appendChild(opt);
                    }
                }

                // Show any installation notes returned by the server.
                if (notes && notes.length > 0) {
                    const ul = document.createElement('ul');
                    ul.className = 'mb-0 ps-3';
                    notes.forEach(msg => {
                        const li = document.createElement('li');
                        li.textContent = msg;
                        ul.appendChild(li);
                    });
                    const wrapper = document.createElement('div');
                    wrapper.className = devices.length === 0
                        ? 'alert alert-warning py-2 small'
                        : 'alert alert-info py-2 small';
                    wrapper.appendChild(ul);
                    notesDiv.appendChild(wrapper);
                }

            } catch (e) {
                dropdown.innerHTML = '<option value="">Error contacting scan API</option>';
            } finally {
                btn.disabled  = false;
                btn.innerHTML = '<i class="bi bi-search"></i> Scan';
            }
        };

        // When the user picks a device in the dropdown, update the hidden input.
        document.getElementById('sdrDeviceDropdown').addEventListener('change', function () {
            document.getElementById('sdrDeviceKeyInput').value = this.value;
            updateDeviceKeyDisplay(this.value);
        });

        window.clearSdrDevice = function () {
            document.getElementById('sdrDeviceKeyInput').value = '';
            document.getElementById('sdrDeviceDropdown').innerHTML =
                '<option value="">— SDR disabled —</option>';
            updateDeviceKeyDisplay('');
        };

        function updateDeviceKeyDisplay(key) {
            const el = document.getElementById('sdrDeviceKeyDisplay');
            el.textContent = key ? `Saved key: ${key}` : 'No device saved.';
        }
    </script>
    <script>
        function copyToClipboard(elementId) {
            const element = document.getElementById(elementId);
            const text = element.textContent;
            navigator.clipboard.writeText(text).then(() => {
                // Visual feedback
                const button = event.target.closest('button');
                const originalHTML = button.innerHTML;
                button.innerHTML = '<i class="bi bi-check"></i> Copied!';
                button.classList.remove('btn-outline-primary');
                button.classList.add('btn-success');
                setTimeout(() => {
                    button.innerHTML = originalHTML;
                    button.classList.remove('btn-success');
                    button.classList.add('btn-outline-primary');
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy:', err);
                alert('Failed to copy to clipboard');
            });
        }

        async function testConnection() {
            const btn = event.target;
            const originalHTML = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Testing...';

            try {
                const response = await fetch('/api/cat/reinitialize', { method: 'POST' });
                const data = await response.json();

                if (data.success) {
                    btn.innerHTML = '<i class="bi bi-check-circle"></i> Connected!';
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-success');
                    setTimeout(() => {
                        window.location.href = '/';
                    }, 1000);
                } else {
                    btn.innerHTML = '<i class="bi bi-x-circle"></i> Failed';
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-danger');
                    alert(data.message || 'Connection failed. Check your settings and radio.');
                    setTimeout(() => {
                        btn.innerHTML = originalHTML;
                        btn.classList.remove('btn-danger');
                        btn.classList.add('btn-success');
                        btn.disabled = false;
                    }, 3000);
                }
            } catch (err) {
                btn.innerHTML = '<i class="bi bi-x-circle"></i> Error';
                btn.classList.add('btn-danger');
                alert('Error testing connection: ' + err.message);
                setTimeout(() => {
                    btn.innerHTML = originalHTML;
                    btn.classList.remove('btn-danger');
                    btn.classList.add('btn-success');
                    btn.disabled = false;
                }, 3000);
            }
        }

    </script>
}
